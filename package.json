    "camunda-process-exception-latency-ledger": "./dist/cli.js"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.json",
    "demo": "tsx scripts/run_demo.ts",
    "sql:check": "tsx scripts/check_sql.ts",
    "bpmn:check": "tsx scripts/check_bpmn.ts",
    "prerender": "tsx scripts/prerender.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "verify": "npm run lint && npm run typecheck && npm run coverage && npm run build && npm run demo && npm run sql:check && npm run bpmn:check && npm run prerender && npm run smoke"
  },
  "keywords": [
    "camunda",
    "bpmn",
    "process-mining",
    "workflow",
    "incident-management",
    "executive-intelligence",
    "kinetic-gain"
